allback to continuously receive tag information during inventory"}]}],"caption":[],"type":"step","media":null,"code":"inventory-tags-01.swift"},{"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Start RFID tag inventory. The inventoried tags will be returned in the callback"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Tag data callback can also be set via the tagInfoListBlock parameter in the start inventory method, with the same effect as step one"}],"type":"paragraph"}],"type":"step","media":null,"code":"inventory-tags-02.swift"},{"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"When starting inventory, you can pass filter and inventoryParam parameters to implement special functions"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"For example, filter tags with EPC starting with "},{"inlineContent":[{"text":"1111222233334444","type":"text"}],"type":"strong"},{"text":", and report each tag only once","type":"text"}],"type":"paragraph"}],"type":"step","media":null,"code":"inventory-tags-03.swift"},{"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"When you need to stop inventory, call the stop inventory method","type":"text"}]}],"runtimePreview":null,"caption":[],"code":"inventory-tags-04.swift"},{"media":null,"code":"inventory-tags-05.swift","runtimePreview":null,"type":"step","content":[{"inlineContent":[{"text":"You can modify module configuration as needed. Note that RFID module configuration cannot be modified during inventory","type":"text"}],"type":"paragraph"}],"caption":[{"type":"paragraph","inlineContent":[{"text":"For example, set power to 20, set link parameter to Gen2X_Miller8_160KHz, set inventory data area to EPC+TID","type":"text"}]}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/rfidmanager\/getting-started"]}],"identifier":{"url":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Getting-Started","interfaceLanguage":"swift"},"metadata":{"role":"project","title":"Getting Started","categoryPathComponent":"Meet-RFIDManager","category":"RFIDManager"},"references":{"doc://com.rfid.RFIDManager/tutorials/Meet-RFIDManager/Getting-Started":{"identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager\/Getting-Started","role":"article","kind":"article","abstract":[],"url":"\/tutorials\/meet-rfidmanager\/getting-started","type":"topic","title":"Getting Started"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Import-RFIDManager#Local-SDK-File-Import":{"type":"section","url":"\/tutorials\/rfidmanager\/import-rfidmanager#Local-SDK-File-Import","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Import-RFIDManager#Local-SDK-File-Import","kind":"section","abstract":[{"text":"This tutorial introduces two methods to import RFIDManager into your project: Swift Package Manager and local file import","type":"text"}],"title":"Local SDK File Import","role":"pseudoSymbol"},"connect-device-02.swift":{"fileType":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","}",""],"fileName":"ViewController.swift","highlights":[{"line":1},{"line":6},{"line":7},{"line":10},{"line":12},{"line":13},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34}],"type":"file","syntax":"swift","identifier":"connect-device-02.swift"},"inventory-tags-04.swift":{"fileType":"swift","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(filter: nil)","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","","    func stopInventory() {","        let result = RFIDBleManager.shared.stopInventory()","        print(result.code == .success ? \"Inventory stopped\" : \"\\(result.message ?? \"stopInventory failed\")\")","    }","}"],"fileName":"InventoryManager.swift","highlights":[{"line":19},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26}],"type":"file","syntax":"swift","identifier":"inventory-tags-04.swift"},"inventory-tags-03.swift":{"fileType":"swift","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(","            filter: RFIDFilter(","                enable: true, ","                bank: RFIDBank.EPC.rawValue,    \/\/ Filter EPC memory bank","                offset: 32,                     \/\/ Start from bit 32 (skip PC+CRC)","                length: 64,                     \/\/ Filter 64 bits (4 words)","                data: \"1111222233334444\"        \/\/ Filter data in hex","            ),","            inventoryParam: RFIDInventoryParam(unique: true)","        )","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","}"],"fileName":"InventoryManager.swift","highlights":[{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28}],"type":"file","syntax":"swift","identifier":"inventory-tags-03.swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Import-RFIDManager":{"identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Import-RFIDManager","estimatedTime":"10min","abstract":[{"text":"This tutorial introduces two methods to import RFIDManager into your project: Swift Package Manager and local file import","type":"text"}],"kind":"project","type":"topic","role":"project","title":"Import RFIDManager to Project","url":"\/tutorials\/rfidmanager\/import-rfidmanager"},"connect-device-05.swift":{"fileType":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func stopScanning() {","        \/\/ Stop scanning for peripherals","        \/\/ 停止扫描外设","        RFIDBleManager.shared.stopForPeripherals()","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"fileName":"ViewController.swift","highlights":[{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46}],"type":"file","syntax":"swift","identifier":"connect-device-05.swift"},"connect-device-03.swift":{"fileType":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","